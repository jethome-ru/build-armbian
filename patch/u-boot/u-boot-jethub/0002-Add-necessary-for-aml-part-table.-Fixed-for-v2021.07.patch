+static inline int isstring(char *p)
+{
+	char *endptr = p;
+	while (*endptr != '\0') {
+		if (!(((*endptr >= '0') && (*endptr <= '9'))
+				|| ((*endptr >= 'a') && (*endptr <= 'f'))
+				|| ((*endptr >= 'A') && (*endptr <= 'F'))
+				|| (*endptr == 'x') || (*endptr == 'X')))
+			return 1;
+		endptr++;
+	}
+
+	return 0;
+}
