+						n = blk_derase(mmc_get_blk_desc(mmc), blk, cnt);
+					printf("dev # %d, %s, several blocks erased %s\n",
+							dev, (flag == 0) ? " ":(argv[2]),(n == 0) ? "OK" : "ERROR");
+					return (n == 0) ? 0 : 1;
+				}else if (strcmp(argv[2], "key") == 0){
