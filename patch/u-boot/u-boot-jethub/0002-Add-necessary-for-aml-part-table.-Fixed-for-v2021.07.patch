+	if ((byte > 191) || (byte < 0)) {
+		printf("byte is not able to write!\n");
+		return 1;
+	}
+
+	mmc = find_mmc_device(dev);
+
+	if (!mmc) {
+		puts("no mmc devices available\n");
+		return 1;
+	}
+
+	mmc_init(mmc);
+
+	ret = mmc_set_ext_csd(mmc, byte, val);
+	printf("write EXT_CSD byte[%d] val[0x%x] %s\n",
+			byte, val, (ret == 0) ? "ok" : "fail");
+	ret =ret || ret;
+	return ret;
+}
