From 253006ea4caff68411a49617cfc8b7b0115ce660 Mon Sep 17 00:00:00 2001
From: Vyacheslav Bocharov <devel@lexina.in>
Date: Thu, 10 Jun 2021 13:24:41 +0300
Subject: [PATCH 07/11] Add restore GPT table from ept (for cases when first
 GPT record is lost)

---
 drivers/mmc/aml_emmc_partition.c | 2 ++
 1 file changed, 2 insertions(+)

diff --git a/drivers/mmc/aml_emmc_partition.c b/drivers/mmc/aml_emmc_partition.c
index 954dab3668c..9a16c51fd01 100644
--- a/drivers/mmc/aml_emmc_partition.c
+++ b/drivers/mmc/aml_emmc_partition.c
@@ -1394,6 +1394,8 @@ int mmc_device_init (struct mmc *mmc)
 		if (gpt_priority) {
 			fill_ept_by_gpt(mmc, p_iptbl_ept);
 			printf("and gpt has higher priority, so ept had been update\n");
+			trans_ept_to_diskpart(p_iptbl_ept, disk_partition);
+			gpt_restore(mmc_get_blk_desc(mmc), str_disk_guid, disk_partition, dcount);
 		} else {
 			gpt_restore(mmc_get_blk_desc(mmc), str_disk_guid, disk_partition, dcount);
 			printf("but EPT has higher priority, so gpt had been recover\n");
-- 
