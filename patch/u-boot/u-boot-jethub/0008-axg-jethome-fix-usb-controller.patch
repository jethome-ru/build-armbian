From 113f111eb2af3aafde3c47e7b958fb2e413310e3 Mon Sep 17 00:00:00 2001
From: Vyacheslav Bocharov <devel@lexina.in>
Date: Sun, 27 Jun 2021 20:17:27 +0300
Subject: [PATCH 08/11] axg, jethome: fix usb controller

---
 arch/arm/dts/meson-axg-jethome-jethub-j100.dts          | 4 ++--
 configs/{jethub-d1_defconfig => jethub_d1_v1_defconfig} | 1 +
 configs/{jethub-d2_defconfig => jethub_d2_v1_defconfig} | 0
 configs/{jethub-h1_defconfig => jethub_h1_v1_defconfig} | 0
 4 files changed, 3 insertions(+), 2 deletions(-)
 rename configs/{jethub-d1_defconfig => jethub_d1_v1_defconfig} (98%)
 rename configs/{jethub-d2_defconfig => jethub_d2_v1_defconfig} (100%)
 rename configs/{jethub-h1_defconfig => jethub_h1_v1_defconfig} (100%)

diff --git a/arch/arm/dts/meson-axg-jethome-jethub-j100.dts b/arch/arm/dts/meson-axg-jethome-jethub-j100.dts
index 289a0b582c7..18a6d76a5a8 100644
--- a/arch/arm/dts/meson-axg-jethome-jethub-j100.dts
+++ b/arch/arm/dts/meson-axg-jethome-jethub-j100.dts
@@ -202,7 +202,7 @@
 	}; //End unifykey
 	soc {
 		usb: usb@ffe09080 {
-			compatible = "amlogic,meson-axg-usb-ctrl";
+			compatible = "amlogic,meson-gxl-usb-ctrl";
 			reg = <0x0 0xffe09080 0x0 0x20>;
 			interrupts = <GIC_SPI 16 IRQ_TYPE_LEVEL_HIGH>;
 			#address-cells = <2>;
@@ -219,7 +219,7 @@
 			phy-names = "usb2-phy1";
 
 			dwc2: usb@ff400000 {
-				compatible = "amlogic,meson-g12a-usb", "snps,dwc2";
+				compatible = "amlogic,meson-gxl-usb", "snps,dwc2";
 				reg = <0x0 0xff400000 0x0 0x40000>;
 				interrupts = <GIC_SPI 31 IRQ_TYPE_LEVEL_HIGH>;
 				clocks = <&clkc CLKID_USB1>;
diff --git a/configs/jethub-d1_defconfig b/configs/jethub_d1_v1_defconfig
similarity index 98%
rename from configs/jethub-d1_defconfig
rename to configs/jethub_d1_v1_defconfig
index 032f8ebc9d3..1f2bedb4036 100644
--- a/configs/jethub-d1_defconfig
+++ b/configs/jethub_d1_v1_defconfig
@@ -44,6 +44,7 @@ CONFIG_USB=y
 CONFIG_DM_USB=y
 CONFIG_USB_XHCI_HCD=y
 CONFIG_USB_XHCI_DWC3=y
+CONFIG_USB_DWC2=y
 CONFIG_USB_DWC3=y
 # CONFIG_USB_DWC3_GADGET is not set
 CONFIG_USB_DWC3_MESON_GXL=y
diff --git a/configs/jethub-d2_defconfig b/configs/jethub_d2_v1_defconfig
similarity index 100%
rename from configs/jethub-d2_defconfig
rename to configs/jethub_d2_v1_defconfig
diff --git a/configs/jethub-h1_defconfig b/configs/jethub_h1_v1_defconfig
similarity index 100%
rename from configs/jethub-h1_defconfig
rename to configs/jethub_h1_v1_defconfig
-- 
2.30.2

