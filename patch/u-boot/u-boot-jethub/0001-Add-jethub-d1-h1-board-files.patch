+	meson-gxl-s905w-jethome-jethub-j80.dtb \
+	meson-axg-jethome-jethub-j100.dtb
 dtb-$(CONFIG_ARCH_TEGRA) += tegra20-harmony.dtb \
 	tegra20-medcom-wide.dtb \
